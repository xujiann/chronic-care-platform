# chronic-care-platform environment template

# HTTP port used by server.js. Defaults to 5173.
PORT=5173

# Runtime environment label shown by /api/health and /api/metrics.
NODE_ENV=production

# Storage engine: auto, sqlite, or json.
# auto uses node:sqlite when the runtime supports it and keeps data/db.json as a static snapshot.
STORAGE_ENGINE=auto

# Required when STORAGE_ENGINE=postgres or postgresql.
# DATABASE_URL=postgres://health:replace-with-password@postgres.internal:5432/chronic_care

# Optional external data directory. Defaults to ./data.
# DATA_DIR=/var/lib/chronic-care-platform

# Comma-separated session signing secrets. Put the newest first during rotation.
SESSION_SECRETS=replace-with-long-random-secret

# HMAC signing secret for integration gateway simulation.
INTEGRATION_GATEWAY_SECRET=replace-with-integration-secret

# Production government identity adapter. Required by env:check:production.
# OIDC_ISSUER_URL=https://identity.example.gov.cn/real-issuer
# OIDC_CLIENT_ID=replace-with-oidc-client-id
# OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
# CA_GATEWAY_URL=https://ca.example.gov.cn/real-gateway
# SMS_GATEWAY_URL=https://sms.example.gov.cn/real-gateway

# Production audit retention target. At least one of AUDIT_EXPORT_PATH or SIEM_ENDPOINT is required.
# AUDIT_EXPORT_PATH=/var/log/chronic-care-platform/audit
# SIEM_ENDPOINT=https://siem.example.gov.cn/ingest
# RETENTION_POLICY=10y-worm
